{
  "name": "helix-contracts",
  "version": "1.0.0",
  "description": "Helix protocol contracts on Arc Testnet",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy": "hardhat ignition deploy ignition/modules/Deploy.ts --network arcTestnet",
    "deploy:local": "hardhat ignition deploy ignition/modules/Deploy.ts",
    "postdeploy": "hardhat run scripts/postDeploy.ts --network arcTestnet",
    "abis": "node scripts/extractAbis.mjs",
    "gen:crank": "node scripts/genCrankKey.mjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.6",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "hardhat": "^3.5.1",
    "typescript": "^6.0.3",
    "viem": "^2.50.4"
  }
}
